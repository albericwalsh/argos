{
  "id": "test_workflow",
  "name": "Test Workflow",
  "description": "Workflow de test ARGOS",
  
  "inputs": {
    "domaine": "string",
    "name": "string",
    "date": "string"
  },

  "steps": [
    {
      "id": "step1",
      "module": "nmap",
      "args": {
        "target": "$inputs.domaine"
      },
      "output": {
        "port": "int",
        "protocol": "str",
        "state": "str",
        "name": "str",
        "product": "str",
        "version": "str"
      }
    },
    {
      "id": "step2",
      "module": "vulnerability_scanner",
      "depends_on": ["step1"],
      "args": {
        "scan_results": "$step1.output.product"
      },
      "output": "vulnerability_report"
    }
  ]
}