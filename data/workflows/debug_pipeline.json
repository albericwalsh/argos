{
  "id": "debug_pipeline",
  "name": "Debug Pipeline",
  "description": "Teste le passage d'output entre deux steps",

  "inputs": {
    "text": "",
    "count": ""
  },

  "steps": [
    {
      "id": "step1",
      "module": "debug_input",
      "args": {
        "text": "$inputs.text",
        "count": "$inputs.count"
      }
    },
    {
      "id": "step2",
      "module": "debug_output",
      "depends_on": ["step1"],
      "args": {
        "items": "$step1.output"
      }
    }
  ]
}